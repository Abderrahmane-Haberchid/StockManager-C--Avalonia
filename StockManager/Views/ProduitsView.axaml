<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:StockManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModels:ProduitsViewModel"
             x:Class="StockManager.Views.ProduitsView">
    
    <Design.DataContext>
        <viewModels:ProduitsViewModel/>
    </Design.DataContext>
    
    <StackPanel Orientation="Vertical" Spacing="30" HorizontalAlignment="Center">
          <TextBlock Text="Ajouter Produit" Margin="0 30" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
          
          <StackPanel  HorizontalAlignment="Left">
              <TextBlock Text="Nom produit" Margin="0 10" />
              <TextBox Watermark="Nom du produit..." Width="400" />
          </StackPanel>
          
          <StackPanel Orientation="Vertical">
              <TextBlock Text="Catégorie" Margin="0 10" />
              <ComboBox Width="400" SelectedItem="0">
                  <ComboBoxItem>Chauffe-eau</ComboBoxItem>
                  <ComboBoxItem>Four</ComboBoxItem>
                  <ComboBoxItem>TV</ComboBoxItem>
                  <ComboBoxItem>Machine à Laver</ComboBoxItem>
                  <ComboBoxItem>Lave vaisselle</ComboBoxItem>
                  <ComboBoxItem>Frégidaire</ComboBoxItem>
                  <ComboBoxItem>Micro-onde</ComboBoxItem>
              </ComboBox>
          </StackPanel>
        
          
          <StackPanel Orientation="Horizontal" Spacing="40">
              <StackPanel>
                  <TextBlock Text="Prix" Margin="0 10" />
                  <TextBox Watermark="Prix..." Width="180"></TextBox>
              </StackPanel>
              
              <StackPanel>
                  <TextBlock Text="Quantité" Margin="0 10" />
                  <TextBox Watermark="Quantité..." Width="180" />
              </StackPanel>
              
          </StackPanel>
          
          <Button Content="Valider produit" 
                  Width="400" 
                  CornerRadius="5" 
                  FontSize="20"
                  FontWeight="Bold"
                  Height="30"  
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Command="{Binding A}"/>
          
    </StackPanel>
    
</UserControl>
